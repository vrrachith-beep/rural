rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /complaints/{complaintId} {
      allow read: if false;
      allow write: if false;
    }

    match /chatSessions/{sessionId} {
      allow read: if false;
      allow write: if false;

      match /messages/{messageId} {
        allow read: if false;
        allow write: if false;
      }
    }
  }
}
